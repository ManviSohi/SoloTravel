<% layout("/layouts/boilerplate") %>

<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const listing = <%- JSON.stringify(listing) %>;
</script>

<div class="container my-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10 col-sm-12">
      <h3 class="text-center mb-3"><%= listing.title %></h3>

      <!--  Updated Listing Image Section -->
      <div class="card show-card">
        <div class="image-container">
          <img
            src="<%= listing.image.url %>"
            alt="listing_image"
            class="listing-image"
          />
          <div class="image-overlay">
            <h5><%= listing.title %></h5>
            <p><%= listing.location %>, <%= listing.country %></p>
          </div>
        </div>

        <!--  Updated Card Body Section -->
        <div class="card-body listing-details">
          <div class="owner-info mb-3">
            <p class="card-text mb-1">
              <i class="fa-solid fa-user-circle me-2" style="color:#fe424d;"></i>
              <strong>Owned by:</strong> <i><%= listing.owner.username %></i>
            </p>
          </div>

          <!--  Description Section -->
          <div class="listing-description mb-4 p-3 rounded" 
               style="background-color:#fff5f5; border-left:5px solid #fe424d;">
            <p class="card-text text-dark mb-0" style="line-height:1.6;">
              <i class="fa-solid fa-align-left me-2" style="color:#fe424d;"></i>
              <%= listing.description %>
            </p>
          </div>

          <!--  Price &  Location -->
          <div class="price-location">
            <p class="price mb-2">
              <i class="fa-solid fa-tag me-2" style="color:#fe424d;"></i>
              <strong>Price:</strong>
              &#8377;
              <%= listing.price != null ? listing.price.toLocaleString("en-IN") : "Price not available" %>
            </p>

            <p class="location mb-0">
              <i class="fa-solid fa-location-dot me-2" style="color:#fe424d;"></i>
              <strong>Location:</strong> <%= listing.location %>, <%= listing.country %>
            </p>
          </div>
        </div>
      </div>

      <!--  Booking Section -->
      <div class="text-center my-3">
        <% if (!currUser) { %>
          <a href="/login" class="btn btn-airbnb px-4 py-2">Login to Book</a>
        <% } else if (listing.owner && currUser && !listing.owner._id.equals(currUser._id)) { %>
          <form id="bookingForm" action="/listings/<%= listing._id %>/book" method="POST">
            <button type="submit" class="btn btn-airbnb px-4 py-2">Book Now</button>
          </form>
        <% } else { %>
          <p class="text-muted">You are the owner of this listing.</p>
        <% } %>
      </div>

      <!--  Owner Controls -->
      <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
      <div class="btns">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-airbnb w-100 w-md-auto">Edit</a>
        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="w-100 w-md-auto">
          <button class="btn btn-airbnb w-100">Delete</button>
        </form>
      </div>
      <% } %>

      <!--  Reviews Section -->
      <div class="review-section mt-5">
        <h4 class="mb-4">Reviews</h4>

        <% if (listing.reviews.length === 0) { %>
          <p class="text-muted">No reviews yet. Be the first to share your experience!</p>
        <% } else { %>
          <% listing.reviews.forEach(review => { %>
            <div class="review">
              <strong><%= review.author.username %></strong>
              <small class="text-muted"> – <%= review.createdAt.toDateString() %></small>
              <p class="mt-2"><%= review.comment %></p>

              <% if (review.rating) { %>
                <p>
                  <% for (let i = 0; i < review.rating; i++) { %>
                    <span style="color:#ffb400;">★</span>
                  <% } %>
                  <% for (let i = review.rating; i < 5; i++) { %>
                    <span style="color:#ccc;">★</span>
                  <% } %>
                </p>
              <% } %>

              <% if (currUser && review.author && currUser._id.equals(review.author._id)) { %>
                <form
                  class="delete-review-form"
                  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                  method="POST"
                >
                  <button class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
              <% } %>
            </div>
          <% }) %>
        <% } %>

        <% if (currUser && (!listing.owner._id.equals(currUser._id))) { %>
          <hr />
          <form
            id="reviewForm"
            class="review-form mt-3"
            action="/listings/<%= listing._id %>/reviews"
            method="POST"
          >
            <div class="star-rating" aria-label="Rating">
              <input type="radio" id="star5" name="review[rating]" value="5" required><label for="star5">★</label>
              <input type="radio" id="star4" name="review[rating]" value="4"><label for="star4">★</label>
              <input type="radio" id="star3" name="review[rating]" value="3"><label for="star3">★</label>
              <input type="radio" id="star2" name="review[rating]" value="2"><label for="star2">★</label>
              <input type="radio" id="star1" name="review[rating]" value="1"><label for="star1">★</label>
            </div>

            <textarea name="review[comment]" placeholder="Write your review..." required></textarea>
            <button class="btn btn-airbnb btn-sm px-4 mt-2">Submit Review</button>
          </form>
        <% } else if (!currUser) { %>
          <p class="text-center text-muted mt-3">Login to write a review.</p>
        <% } %>
      </div>

      <!-- 🗺️ Map Section -->
      <div class="mt-4">
        <h4>Where you'll be</h4>
        <div id="map"></div>
      </div>
    </div>
  </div>
</div>

<!--  External CSS & JS -->
<link rel="stylesheet" href="/css/show.css" />

<!-- Font Awesome for Icons -->
<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"
/>

<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- Custom JS -->
<script src="/js/booking.js"></script>
<script src="/js/review.js"></script>
<script src="/js/deleteReview.js"></script>
<script src="/js/map.js"></script>
