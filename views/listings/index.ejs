<% layout("/layouts/boilerplate") %>
<%= success %>

<style>
/* FILTERS SECTION */
#filters {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    overflow-x: hidden; /* Hide scrollbar */
    white-space: nowrap;
    padding: 1rem;
    background-color: #fff;
    position: relative;
    z-index: 10;
    cursor: grab;
    border-bottom: 1px solid #eee;
}

#filters:active {
    cursor: grabbing;
}

.filter {
    flex: 0 0 auto;
    text-align: center;
    margin-right: 1.2rem;
    margin-top: 1rem;
    opacity: 0.9;
    transition: transform 0.25s ease, opacity 0.25s ease;
    user-select: none;
}

.filter:hover {
    opacity: 1;
    transform: scale(1.08);
    cursor: pointer;
}

.filter i {
    color: #ff385c;
    font-size: 1.4rem;
}

.filter p {
    font-size: 0.8rem;
    margin-top: 0.3rem;
}

/* TAX TOGGLE */
.tax-toggle {
    border: 1px solid #ddd;
    border-radius: 1.5rem;
    padding: 0.7rem 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    background-color: #fff;
    margin-left: auto;
    margin-right: 1rem;
    flex-shrink: 0;
}

/* LISTING CARDS */
.listing-card {
    margin-bottom: 1.5rem;
    border-radius: 1rem;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.listing-card:hover {
    transform: scale(1.02);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.2);
}

.card-img-top {
    object-fit: cover;
    width: 100%;
    height: 20rem;
}

@media (max-width: 576px) {
    .card-img-top {
        height: 15rem;
    }
}

/* TAX INFO */
.tax-info {
    display: none;
}

/* MOBILE RESPONSIVENESS */
@media (max-width: 992px) {
    #filters {
        overflow-x: hidden;
        flex-wrap: nowrap;
        border-radius: 1rem;
    }

    .filter {
        margin-right: 1rem;
        font-size: 0.9rem;
    }

    .tax-toggle {
        flex: 0 0 auto;
        font-size: 0.8rem;
        border: 1px solid #ccc;
    }
}

/* Hide hamburger completely */
#menu-btn {
    display: none !important;
}
</style>

<body>
    <!-- FILTERS SECTION -->
    <div id="filters">
        <div class="filter"><i class="fa-solid fa-fire"></i><p>Trending</p></div>
        <div class="filter"><i class="fa-solid fa-bed"></i><p>Rooms</p></div>
        <div class="filter"><i class="fa-solid fa-mountain-city"></i><p>Cities</p></div>
        <div class="filter"><i class="fa-solid fa-mountain"></i><p>Mountains</p></div>
        <div class="filter"><i class="fa-brands fa-fort-awesome"></i><p>Castles</p></div>
        <div class="filter"><i class="fa-solid fa-person-swimming"></i><p>Pools</p></div>
        <div class="filter"><i class="fa-solid fa-tents"></i><p>Camping</p></div>
        <div class="filter"><i class="fa-solid fa-cow"></i><p>Farms</p></div>
        <div class="filter"><i class="fa-solid fa-snowflake"></i><p>Arctic</p></div>
        <div class="filter"><i class="fa-solid fa-igloo"></i><p>Domes</p></div>
        <div class="filter"><i class="fa-solid fa-ship"></i><p>Boats</p></div>

        <!-- TAX TOGGLE -->
        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault" />
                <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>
    </div>

    <!-- LISTINGS SECTION -->
    <div class="container mt-3">
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
            <% for(let listing of allListings) { %>
            <a href="/listings/<%= listing._id %>" class="listing-link text-decoration-none text-dark">
                <div class="card col listing-card">
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" />
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= listing.title %></b> <br />
                            &#8377;
                            <%= listing.price != null ? listing.price.toLocaleString("en-IN") : "Price not available" %> / night
                            <i class="tax-info">&nbsp;&nbsp;+18% GST</i>
                        </p>
                    </div>
                </div>
            </a>
            <% } %>
        </div>
    </div>

    <script>
        // Tax toggle logic
        const taxSwitch = document.getElementById("switchCheckDefault");
        if (taxSwitch) {
            taxSwitch.addEventListener("click", () => {
                const taxInfo = document.getElementsByClassName("tax-info");
                for (let info of taxInfo) {
                    info.style.display =
                        info.style.display !== "inline" ? "inline" : "none";
                }
            });
        }

        // Custom drag scroll for filters
        const slider = document.getElementById("filters");
        let isDown = false;
        let startX;
        let scrollLeft;

        slider.addEventListener("mousedown", (e) => {
            isDown = true;
            slider.classList.add("active");
            startX = e.pageX - slider.offsetLeft;
            scrollLeft = slider.scrollLeft;
        });

        slider.addEventListener("mouseleave", () => {
            isDown = false;
        });

        slider.addEventListener("mouseup", () => {
            isDown = false;
        });

        slider.addEventListener("mousemove", (e) => {
            if (!isDown) return;
            e.preventDefault();
            const x = e.pageX - slider.offsetLeft;
            const walk = (x - startX) * 1.5; // scroll speed multiplier
            slider.scrollLeft = scrollLeft - walk;
        });

        // Touch support for mobile
        let touchStartX = 0;
        let touchScrollLeft = 0;

        slider.addEventListener("touchstart", (e) => {
            touchStartX = e.touches[0].pageX;
            touchScrollLeft = slider.scrollLeft;
        });

        slider.addEventListener("touchmove", (e) => {
            const x = e.touches[0].pageX;
            const walk = (x - touchStartX) * 1.5;
            slider.scrollLeft = touchScrollLeft - walk;
        });
    </script>
</body>
